# =============================================================
#  BizPlay Secure RAG Chatbot API ??Environment Variables
#  Copy this file to .env and fill in values before running.
#  NEVER commit .env to version control.
# =============================================================

# --------------------------
# PostgreSQL
# --------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:9011/bizplay
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=123

# --------------------------
# Testing UI login (only protects the static UI at / ??API stays public)
# --------------------------
UI_USERNAME=bizplay
UI_PASSWORD=bizplay@2026

# --------------------------
# LLM Models
# Each model uses a numbered prefix (LLM_0_*, LLM_1_*, etc.)
# Add more models by incrementing the number.
# --------------------------
LLM_DEFAULT_MODEL=exaone-3.5-7.8b

# Model 0
LLM_0_NAME=exaone-3.5-7.8b
LLM_0_LABEL=EXAONE-3.5-7.8B
LLM_0_BASE_URL=http://10.255.78.58:9020/api/v1/exaone-357-8b-instruct-awq
LLM_0_API_KEY=sk-d7a20eb034c847e8994e192b40c69a61
LLM_0_MODEL=exaone-357-8b-instruct-awq

# Model 1
LLM_1_NAME=gemma-4-8b
LLM_1_LABEL=Gemma-4-8B
LLM_1_BASE_URL=http://10.255.78.58:9020/api/v1/gemma-4-E4B-8b-instruct
LLM_1_API_KEY=sk-d7a20eb034c847e8994e192b40c69a61
LLM_1_MODEL=gemma-4-E4B-8b-instruct

# --------------------------
# vLLM ??Embedding server (BAAI/bge-m3)
# Start: vllm serve BAAI/bge-m3 --task embed --port 8006
# --------------------------
EMBED_BASE_URL=http://10.255.78.58:8006
EMBED_MODEL=bge-m3
EMBED_API_KEY=vlm-tk-db590fa411091cb9426deeebec90e7c0

# --------------------------
# Reranker (BAAI/bge-reranker-v2-m3)
# Set RERANKER_ENABLED=true and configure the URL to activate.
# Serve via: vllm serve BAAI/bge-reranker-v2-m3 --task score --port 8007
# --------------------------
RERANKER_ENABLED=true
RERANKER_BASE_URL=http://10.255.78.58:8007
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_API_KEY=vlm-tk-db590fa411091cb9426deeebec90e7c0

